{
  "name": "arcis-deploy",
  "version": "1.0.0",
  "type": "module",
  "description": "Arcis Protocol — deploy to Base mainnet",
  "scripts": {
    "deploy": "npx hardhat run scripts/deploy.js --network base",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network baseSepolia",
    "strategy": "npx hardhat run scripts/deploy-strategy.js --network base",
    "execute": "npx hardhat run scripts/execute-strategy.js --network base",
    "seed": "npx hardhat run scripts/seed-deposit.js --network base",
    "status": "npx hardhat run scripts/status.js --network base",
    "verify": "npx hardhat run scripts/verify.js --network base"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0"
  }
}
